<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.backend.mapper.RolePermissionMapper">
    <resultMap id="rolePermissionMap" type="com.example.backend.entity.RolePermission">
        <id property="id" column="id" />
        <result property="roleName" column="role_name" />
        <result property="permissionNames" column="permission_names" />
        <result property="description" column="description" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <select id="findAll" resultMap="rolePermissionMap">
        SELECT * FROM role_permission ORDER BY id ASC
    </select>

    <select id="findById" parameterType="Long" resultMap="rolePermissionMap">
        SELECT * FROM role_permission WHERE id = #{id}
    </select>

    <select id="findByRoleName" parameterType="String" resultMap="rolePermissionMap">
        SELECT * FROM role_permission WHERE role_name = #{roleName}
    </select>

    <insert id="insert" parameterType="com.example.backend.entity.RolePermission" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO role_permission (role_name, permission_names, description)
        VALUES (#{roleName}, #{permissionNames}, #{description})
    </insert>

    <update id="update" parameterType="com.example.backend.entity.RolePermission">
        UPDATE role_permission
        SET permission_names = #{permissionNames},
            description = #{description},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        DELETE FROM role_permission WHERE id = #{id}
    </delete>
</mapper>
