<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.backend.mapper.ArticleContentMapper">
    <resultMap id="articleContentMap" type="com.example.backend.entity.ArticleContent">
        <id property="id" column="id" />
        <result property="articleId" column="article_id" />
        <result property="content" column="content" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <select id="findByArticleId" parameterType="Long" resultMap="articleContentMap">
        SELECT * FROM article_content WHERE article_id = #{articleId}
    </select>

    <insert id="insert" parameterType="com.example.backend.entity.ArticleContent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO article_content (article_id, content, created_at, updated_at)
        VALUES (#{articleId}, #{content}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.example.backend.entity.ArticleContent">
        UPDATE article_content
        SET content = #{content},
            updated_at = NOW()
        WHERE article_id = #{articleId}
    </update>

    <delete id="deleteByArticleId" parameterType="Long">
        DELETE FROM article_content WHERE article_id = #{articleId}
    </delete>
</mapper>
