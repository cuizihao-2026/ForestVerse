<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.backend.mapper.NotificationMapper">
    <resultMap id="notificationMap" type="com.example.backend.entity.Notification">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="type" column="type" />
        <result property="title" column="title" />
        <result property="message" column="message" />
        <result property="read" column="read" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <select id="findByUserId" parameterType="Long" resultMap="notificationMap">
        SELECT * FROM notification WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="findUnreadByUserId" parameterType="Long" resultMap="notificationMap">
        SELECT * FROM notification WHERE user_id = #{userId} AND `read` = 0 ORDER BY created_at DESC
    </select>

    <insert id="insert" parameterType="com.example.backend.entity.Notification" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notification (user_id, type, title, message, `read`, created_at)
        VALUES (#{userId}, #{type}, #{title}, #{message}, #{read}, #{createdAt})
    </insert>

    <update id="markAsRead" parameterType="Long">
        UPDATE notification SET `read` = 1 WHERE id = #{id}
    </update>

    <update id="markAllAsRead" parameterType="Long">
        UPDATE notification SET `read` = 1 WHERE user_id = #{userId}
    </update>

    <delete id="deleteReadByUserId" parameterType="Long">
        DELETE FROM notification WHERE user_id = #{userId} AND `read` = 1
    </delete>

    <delete id="deleteById" parameterType="Long">
        DELETE FROM notification WHERE id = #{id}
    </delete>
</mapper>
